# =============================================================================
# AI Explanation Engine Configuration
# =============================================================================

# OpenAI API Configuration
OPENAI_API_KEY=sk-proj-your-api-key-here

# LLM Model Selection
# Options: gpt-4o-mini (recommended), gpt-4o, gpt-3.5-turbo
LLM_MODEL=gpt-4o-mini

# LLM Generation Parameters
LLM_TEMPERATURE=0.7          # Creativity level (0.0-2.0). Lower = more factual
LLM_MAX_TOKENS=150           # Max response length
LLM_TIMEOUT=5                # API timeout in seconds
LLM_MAX_RETRIES=1            # Number of retry attempts

